# Contact360 App — production (EC2 / PM2)
# Copy: cp .env.production.example .env.production
# Next.js loads .env.production automatically when NODE_ENV=production (next build / next start).

# ── Public URLs (browser + server) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://api.contact360.io
NEXT_PUBLIC_GRAPHQL_URL=http://api.contact360.io/graphql

NEXT_PUBLIC_API_VERSION=v3
NEXT_PUBLIC_AUTH_API_VERSION=v1
NEXT_PUBLIC_USER_API_VERSION=v1
NEXT_PUBLIC_VQL_API_VERSION=v3

NEXT_PUBLIC_JOBS_S3_BUCKET=appointment360uploads

NEXT_PUBLIC_EXPORTS_FEATURE_ENABLED=false
NEXT_PUBLIC_ENABLE_GEOLOCATION=true
NEXT_PUBLIC_GEOLOCATION_TIMEOUT=5000

# ── Server listen (PM2 / ecosystem.config.js also reads PORT) ─────────────
PORT=3000

# ── Optional: deploy script hooks (ec2-deploy.sh / ec2-update.sh) ───────────
# Path to contact360.io/api repo on same host — enables optional DB schema check
# CONTACT360_API_ROOT=/home/ubuntu/contact360/api
# SKIP_DB_CHECK=0
# API health URL override (default: NEXT_PUBLIC_API_URL + /graphql or /health)
# API_HEALTH_URL=http://api.contact360.io/health
