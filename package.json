{
  "name": "contact360-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "next dev --turbo",
    "build": "next build",
    "build:turbo": "next build --turbo",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:responsive": "playwright test --project=mobile-chrome --project=ipad --project=desktop --project=wide",
    "clean": "rimraf .next out dist",
    "clean:all": "npm run clean",
    "prepare": "husky",
    "pre-push": "npm run typecheck && npm run lint && npm run test",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run css:inventory && npm run check:best-practices && npm run build",
    "check:best-practices": "node scripts/check-best-practices.mjs",
    "codegen": "node --use-system-ca ./node_modules/@graphql-codegen/cli/cjs/bin.js --config codegen.ts",
    "codegen:local": "graphql-codegen --config codegen.local.ts",
    "health:smoke": "node scripts/health-smoke.mjs",
    "css:inventory": "node scripts/css-inventory.mjs"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.0.4",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-virtual": "^3.13.18",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "date-fns": "^3.0.0",
    "framer-motion": "^12.33.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "lucide-react": "^0.454.0",
    "next": "^16.1.1",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.0.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.13.3",
    "sonner": "^2.0.7",
    "sweetalert2": "^11.26.24",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@next/bundle-analyzer": "^15.0.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.9.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.3",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "d3-color": ">=3.1.0"
  }
}
