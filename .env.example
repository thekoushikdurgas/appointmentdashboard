# Contact360 App — Environment Variables
# Copy to .env.local for local development

# Public app URL (used in README/deploy; optional for client-side absolute links)
# NEXT_PUBLIC_APP_URL=https://app.contact360.io

# GraphQL API base (no trailing slash). Production default in code is https://api.contact360.io.
# For local FastAPI use http://127.0.0.1:8000 — never :3000 (Next dev) or the /graphql rewrite
# proxies to itself and returns 500 / ENOBUFS.
NEXT_PUBLIC_API_URL=https://api.contact360.io
# In development, omit NEXT_PUBLIC_GRAPHQL_URL to use http://localhost:3000/graphql (same-origin;
# next.config rewrites it to GRAPHQL_UPSTREAM_URL). Setting this to api.contact360.io from the
# browser triggers CORS unless the API allows http://localhost:3000.
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/graphql
# Upstream for dev rewrites only (must not be localhost:3000). Match your gateway scheme.
GRAPHQL_UPSTREAM_URL=https://api.contact360.io

# Super-admins: “Open admin console” link on Settings (ops / logs; see contact360.io/admin)
# NEXT_PUBLIC_ADMIN_URL=https://admin.contact360.io

# S3 / Jobs
NEXT_PUBLIC_JOBS_S3_BUCKET=appointment360uploads

# Feature flags
NEXT_PUBLIC_EXPORTS_FEATURE_ENABLED=false
NEXT_PUBLIC_ENABLE_GEOLOCATION=true
NEXT_PUBLIC_GEOLOCATION_TIMEOUT=5000
